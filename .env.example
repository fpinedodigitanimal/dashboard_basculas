# Variables de entorno - Backend API

# Token API Digitanimal Labs (OBLIGATORIO para modo producción)
DIGITANIMAL_TOKEN=your_token_here

# Token RemoteIoT (OBLIGATORIO para modo producción)
REMOTEIOT_TOKEN=your_remoteiot_token_here

# Autenticación
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Puerto del servidor backend
PORT=8050

# Modo debug
DEBUG=1

# Modo DEMO (1 = sin conexión a labs2)
DEMO_MODE=1

# Clave secreta para sesiones (generar una aleatoria en producción)
SECRET_KEY=dev-secret-key-change-in-production

# CORS - Orígenes permitidos (separados por comas)
# Ejemplo: https://tu-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Timeouts (opcional)
REMOTEIOT_TIMEOUT_S=30
BASCULAS_DATA_REFRESH_MS=100000

# Cache (opcional)
BASCULAS_CACHE_DIR=./cache

# Autenticación (OBLIGATORIO)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SECRET_KEY=cambia-esta-clave-secreta-en-produccion
BASCULAS_STATS_CACHE_MIN=30
